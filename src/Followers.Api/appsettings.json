{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "InstagramSettings": {
    "BaseUrl": "https://instagram.com",
    "DelayMinBetweenRequestsMs": 1000,
    "DelayMaxBetweenRequestsMs": 10000,
    "RetryDelayMs": 2000,
    "MaxRetryAttempts": 3,
    "MaxConnectionsPerServer": 1,
    "PooledConnectionLifetimeMinutes": 1
  },
  "AllowedHosts": "*"
}
